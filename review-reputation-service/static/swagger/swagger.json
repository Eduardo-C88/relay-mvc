{
  "openapi": "3.0.0",
  "info": {
    "title": "Review & Reputation Service API",
    "version": "1.0.0",
    "description": "API para gerenciar reviews e reputações de usuários.\nPermite criar, ler, atualizar e deletar reviews, e consultar/atualizar a reputação de usuários."
  },
  "servers": [
    {
      "url": "http://localhost:3002",
      "description": "Servidor local de desenvolvimento"
    }
  ],
  "tags": [
    { "name": "Reviews", "description": "Endpoints de avaliação de recursos e usuários" },
    { "name": "Reputation", "description": "Endpoints de cálculo de reputação de usuários" }
  ],
  "paths": {
    "/api/reviews": {
      "post": {
        "tags": ["Reviews"],
        "summary": "Cria uma nova review",
        "security": [{ "bearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ReviewInput" }
            }
          }
        },
        "responses": {
          "201": { "description": "Review criada com sucesso", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Review" } } } },
          "400": { "description": "Erro na requisição (dados inválidos)" },
          "401": { "description": "Não autorizado" }
        }
      },
      "get": {
        "tags": ["Reviews"],
        "summary": "Lista todas as reviews",
        "responses": {
          "200": { "description": "Lista de reviews", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Review" } } } } },
          "400": { "description": "Erro na requisição" }
        }
      }
    },
    "/api/reviews/{id}": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Obtém uma review pelo ID",
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Review encontrada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Review" } } } },
          "404": { "description": "Review não encontrada" }
        }
      },
      "put": {
        "tags": ["Reviews"],
        "summary": "Atualiza uma review existente",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": { "required": true, "content": { "application/json": { "schema": { "$ref": "#/components/schemas/ReviewInput" } } } },
        "responses": {
          "200": { "description": "Review atualizada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Review" } } } },
          "404": { "description": "Review não encontrada" },
          "401": { "description": "Não autorizado" }
        }
      },
      "delete": {
        "tags": ["Reviews"],
        "summary": "Deleta uma review",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "204": { "description": "Review deletada com sucesso" },
          "404": { "description": "Review não encontrada" },
          "401": { "description": "Não autorizado (apenas admins)" }
        }
      }
    },
    "/api/reviews/user/{userId}": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Obtém todas as reviews de um usuário",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Lista de reviews do usuário", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Review" } } } } },
          "404": { "description": "Usuário não encontrado" }
        }
      }
    },
    "/api/reviews/resource/{resourceId}": {
      "get": {
        "tags": ["Reviews"],
        "summary": "Obtém todas as reviews de um recurso",
        "parameters": [{ "name": "resourceId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Lista de reviews do recurso", "content": { "application/json": { "schema": { "type": "array", "items": { "$ref": "#/components/schemas/Review" } } } } },
          "404": { "description": "Recurso não encontrado" }
        }
      }
    },
    "/api/reputation/{userId}": {
      "get": {
        "tags": ["Reputation"],
        "summary": "Obtém a reputação de um usuário",
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "responses": {
          "200": { "description": "Reputação do usuário", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserReputation" } } } },
          "404": { "description": "Reputação não encontrada" }
        }
      },
      "post": {
        "tags": ["Reputation"],
        "summary": "Atualiza a reputação de um usuário",
        "security": [{ "bearerAuth": [] }],
        "parameters": [{ "name": "userId", "in": "path", "required": true, "schema": { "type": "integer" } }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["roleType","rating"],
                "properties": {
                  "roleType": { "type": "string", "enum": ["BUYER","SELLER"] },
                  "rating": { "type": "number", "minimum": 1, "maximum": 5 }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Reputação atualizada", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/UserReputation" } } } },
          "400": { "description": "Dados inválidos" },
          "401": { "description": "Não autorizado" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": { "type": "http", "scheme": "bearer", "bearerFormat": "JWT" }
    },
    "schemas": {
      "Review": {
        "type": "object",
        "properties": {
          "id": { "type": "integer" },
          "reviewerId": { "type": "integer" },
          "reviewedUserId": { "type": "integer" },
          "resourceId": { "type": "integer" },
          "transactionId": { "type": "integer" },
          "transactionType": { "type": "string", "enum": ["BORROW","PURCHASE"] },
          "roleType": { "type": "string", "enum": ["BUYER","SELLER"] },
          "rating": { "type": "integer" },
          "comment": { "type": "string" },
          "createdAt": { "type": "string", "format": "date-time" }
        }
      },
      "ReviewInput": {
        "type": "object",
        "required": ["reviewerId","reviewedUserId","transactionId","transactionType","roleType","rating"],
        "properties": {
          "reviewerId": { "type": "integer" },
          "reviewedUserId": { "type": "integer" },
          "resourceId": { "type": "integer" },
          "transactionId": { "type": "integer" },
          "transactionType": { "type": "string", "enum": ["BORROW","PURCHASE"] },
          "roleType": { "type": "string", "enum": ["BUYER","SELLER"] },
          "rating": { "type": "integer", "minimum": 1, "maximum": 5 },
          "comment": { "type": "string" }
        }
      },
      "UserReputation": {
        "type": "object",
        "properties": {
          "userId": { "type": "integer" },
          "sellerRating": { "type": "number" },
          "sellerReviews": { "type": "integer" },
          "buyerRating": { "type": "number" },
          "buyerReviews": { "type": "integer" },
          "lastUpdated": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}